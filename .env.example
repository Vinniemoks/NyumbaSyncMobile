# NyumbaSync Mobile App Environment Variables
# Copy this file to .env and fill in your values
# For Expo SDK 49+, variables must use EXPO_PUBLIC_ prefix to be available in JS

# API Configuration — backend is hosted on Fly.io
EXPO_PUBLIC_API_URL=https://nyumbasync-api.fly.dev/api
EXPO_PUBLIC_SOCKET_URL=wss://nyumbasync-api.fly.dev

# For local development (Android emulator):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api
# EXPO_PUBLIC_SOCKET_URL=ws://10.0.2.2:3001

# For local development (iOS simulator):
# EXPO_PUBLIC_API_URL=http://localhost:3001/api
# EXPO_PUBLIC_SOCKET_URL=ws://localhost:3001

# Custom production domain (when DNS is ready):
# EXPO_PUBLIC_API_URL=https://api.nyumbasync.com/api
# EXPO_PUBLIC_SOCKET_URL=wss://api.nyumbasync.com

# Environment
NODE_ENV=development

# App Configuration
EXPO_PUBLIC_APP_NAME=NyumbaSync
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_BIOMETRICS=false
